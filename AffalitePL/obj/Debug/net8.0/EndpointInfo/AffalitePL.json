          "categoryId": {
            "type": "integer",
            "format": "int32"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "price": {
            "type": "number",
            "format": "double"
          },
          "stock": {
            "type": "integer",
            "format": "int32"
          },
          "image": {
            "type": "string",
            "format": "binary",
            "nullable": true
          },
          "merchantId": {
            "type": "integer",
            "format": "int32"
